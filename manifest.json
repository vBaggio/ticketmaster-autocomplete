{
  "manifest_version": 3,
  "name": "Ticketmaster Autocomplete",
  "version": "0.1.0",
  "description": "Preenche automaticamente os formulários de checkout do Ticketmaster",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://*.ticketmaster.com.br/*",
    "https://*.ticketmaster.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://*.ticketmaster.com.br/*",
        "https://*.ticketmaster.com/*"
      ],
      "js": [
        "shared/storage.js",
        "content/holder-filler.js",
        "content/card-filler.js",
        "content/ui-injector.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Ticketmaster Autocomplete"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
